# VidChatBox Environment Variables

# OpenAI API Settings (Optional, can also be configured in UI)
OPENAI_API_KEY=

# Gemini API Settings (Optional, can also be configured in UI)
GEMINI_API_KEY=

# Groq API Settings (Optional, can also be configured in UI)
GROQ_API_KEY=

# DeepSeek API Settings (Optional, can also be configured in UI)
DEEPSEEK_API_KEY=

# OpenRouter API Settings (Optional, can also be configured in UI)
OPENROUTER_API_KEY=

# Application Configuration
HOST=127.0.0.1
PORT=8000
DATA_DIR=./backend/data

# YouTube Downloader Proxy (Optional, e.g., http://user:pass@host:port)
# Use this to bypass YouTube rate limits and cloud IP blocks for scraping and downloading.
YOUTUBE_PROXY=
